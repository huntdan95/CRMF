rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Tours: public read, admin write only.
    match /tours/{tourId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bookings: never directly readable from the client.
    // - Customers fetch their booking through a Cloud Function that validates accessToken.
    // - Admin reads via the authenticated admin app.
    // - All writes go through Cloud Functions (transactional, capacity-checked).
    match /bookings/{bookingId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Blackouts: public read (so the booking UI can render availability),
    // admin write only.
    match /blackouts/{blackoutId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings (cancellation policy text, email templates): public read,
    // admin write.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit log: admin-only read, writes only via Cloud Functions.
    match /auditLog/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Reschedule requests (customer-initiated, processed manually by Travis
    // in v1): admin-only read, writes only via Cloud Functions.
    match /rescheduleRequests/{requestId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Stripe webhook event log (idempotency dedupe): functions-only.
    match /stripeWebhookEvents/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Contact form messages: write via server action; admin reads.
    match /contactMessages/{msgId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    function isAdmin() {
      // TODO: replace with the real admin email before launch, or migrate to
      // a custom claim (`request.auth.token.admin == true`) when more than
      // one admin is needed.
      return request.auth != null &&
        request.auth.token.email == 'travisurbin1@gmail.com';
    }
  }
}
