# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
#
# In production these are managed via Firebase App Hosting secrets
# (see apphosting.yaml). For local dev you populate them here.

# ---------------------------------------------------------------------------
# Firebase web SDK config (public — shipped to the browser).
# Get these from: Firebase console → Project settings → Your apps → Web app.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin allowlist — the email Travis logs in with at /admin.
# Used by middleware and Firestore security rules.
NEXT_PUBLIC_ADMIN_EMAIL=

# ---------------------------------------------------------------------------
# Firebase Admin SDK (server-only).
# Create a service account in: Firebase console → Project settings →
# Service accounts → Generate new private key. The JSON file gives you these.
# In Firebase App Hosting / Cloud Run, leave these blank — Application
# Default Credentials are used automatically.
# Note: keep \n escapes in FIREBASE_ADMIN_PRIVATE_KEY when pasting from the
# JSON — admin.ts converts them back to real newlines.
# ---------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Stripe (server-only on the function side; publishable key is sent to client).
# Get these from: stripe.com → Developers → API keys. Use test keys until
# the Stripe account is live-mode-approved for this site.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Resend (transactional email — booking confirmations, cancellations, etc.).
# Get this from: resend.com → API keys. Domain must be verified.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
