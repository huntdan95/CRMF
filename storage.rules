rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Public assets (gallery photos, captain photo): anyone can read,
    // only admin can upload/delete.
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'TODO_ADMIN_EMAIL';
    }
  }
}
